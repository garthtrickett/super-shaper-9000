{
  "name": "super-shaper-9000",
  "type": "module",
    "scripts": {
    "build:wasm": "wasm-pack build ./surfer-wasm --target web --out-dir ../src/lib/client/wasm",
    "dev": "bun run build:wasm && concurrently \"vite\" \"bun run --watch src/server/index.ts\"",
    "build": "bun run build:wasm && tsc && vite build",
    "start": "bun run src/server/index.ts",
    "test:unit": "web-test-runner",
    "test:e2e": "playwright test",
    "test:server": "bun test src/server",
    "test:all": "bun test:server && bun test:e2e && bun test:unit",
    "lint": "eslint . --cache --fix",
    "check-types": "bun install && tsc --noEmit"
  },
  "dependencies": {
    "@effect/platform": "^0.87.12",
    "@effect/platform-browser": "^0.67.12",
    "@effect/platform-bun": "^0.72.17",
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/static": "^1.4.7",
    "@open-wc/testing": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@preact/signals-core": "^1.11.0",
    "effect": "^3.16.12",
    "elysia": "^1.4.18",
    "lit": "^3.3.1",
    "rhino3dm": "^8.4.0",
    "sinon": "^21.0.2",
    "three": "^0.162.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.11",
    "@tailwindcss/vite": "^4.1.11",
    "@types/bun": "^1.1.0",
    "@types/mocha": "^10.0.0",
    "@web/dev-server-esbuild": "^1.0.4",
    "@web/test-runner": "^0.18.2",
    "@types/three": "^0.162.0",
    "@web/test-runner-playwright": "^0.11.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.14.0",
    "eslint-plugin-lit": "^1.11.0",
    "eslint-plugin-wc": "^2.2.1",
    "eslint-plugin-lit-a11y": "^5.1.0",
    "globals": "^15.12.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.14.0",
    "vite": "^7.0.4"
  }
}
